.env
.DS_Store
.cursor/rules/*

# Local build artifacts and IDE caches
#R001: Exclude local build output from version control.
#R015: Support cached-removal cleanup policy for generated artifacts.
#R020: Keep ignored artifact paths untracked after cleanup.
.build/
#R001: Exclude generated SAST reports from version control.
reports/sast/
#R030: Exclude generated dependency freshness reports from version control.
reports/dependency-freshness/
#R035: Exclude LLVM raw profile artifacts from version control.
default.profraw
#R025: Exclude local Python virtual environment directories.
.venv/
#R025: Exclude named project virtual environment directories.
*-venv/
#R005: Exclude Xcode DerivedData and user-specific metadata.
DerivedData/
*.xcuserdatad/
*.xcuserstate
#R010: Keep source and shared project configuration tracked.